{
  "Datadog": {
    "AgentUrl": "http://datadog-agent:8126",
    "DirectLogs": false
  },
  "Jwt": {
    "Secret": "super-secret-key-for-development-only-change-in-production"
  },
  "ExternalApi": {
    "OpenMeteo": {
      "BaseUrl": "https://api.open-meteo.com",
      "WeatherConditionsGet": {
        "MaxRetryAttempts": 3,
        "DelaySeconds": 3,
        "BackoffType": "Exponential"
      }
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    }
  }
}
