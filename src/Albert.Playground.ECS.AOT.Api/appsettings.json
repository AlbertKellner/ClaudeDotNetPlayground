{
  "Datadog": {
    "AgentUrl": "http://datadog-agent:8126",
    "DirectLogs": false
  },
  "Jwt": {
    "Secret": "super-secret-key-for-development-only-change-in-production"
  },
  "ExternalApi": {
    "OpenMeteo": {
      "HttpRequest": {
        "BaseUrl": "https://api.open-meteo.com"
      },
      "CircuitBreaker": {
        "MaxRetryAttempts": 3,
        "DelaySeconds": 3,
        "BackoffType": "Exponential"
      },
      "EndpointCache": {
        "WeatherConditionsGet": {
          "DurationSeconds": 10,
          "ExpirationType": "Absolute"
        }
      }
    },
    "GitHub": {
      "HttpRequest": {
        "BaseUrl": "https://api.github.com",
        "PersonalAccessToken": ""
      },
      "CircuitBreaker": {
        "MaxRetryAttempts": 3,
        "DelaySeconds": 5,
        "BackoffType": "Exponential"
      },
      "EndpointCache": {
        "GitHubRepoSearch": {
          "DurationSeconds": 60,
          "ExpirationType": "Absolute"
        }
      }
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    }
  }
}
